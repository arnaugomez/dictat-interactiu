{
  "name": "@dictat/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:check": "oxlint src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "check": "tsc --noEmit && oxlint src && oxfmt --check src",
    "fix": "oxlint --fix src && oxfmt --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dictat/shared": "workspace:*",
    "@effect/platform-bun": "4.0.0-beta.50",
    "drizzle-orm": "*",
    "effect": "4.0.0-beta.50",
    "resend": "*"
  },
  "devDependencies": {
    "drizzle-kit": "*",
    "vitest": "*",
    "@effect/vitest": "*",
    "typescript": "*",
    "bun-types": "*"
  }
}
