{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "fix": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {},
    "test:e2e": {
      "cache": false
    },
    "test:e2e:ui": {
      "cache": false,
      "persistent": true
    }
  }
}
